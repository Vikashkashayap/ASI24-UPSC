PORT=5000
DATABASE_URL=your-mongodb-connection-string
MONGODB_URI=
JWT_SECRET=supersecretjwtkey

# Frontend URL used after OAuth redirects and by backend AI referer headers.
# Local dev: http://localhost:5173
# Production override: https://studentportal.mentorsdaily.com
CLIENT_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Backend public URL (no trailing slash)
# Local dev: http://localhost:5000
# Production override: https://studentportal.mentorsdaily.com
BASE_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
SERVER_URL=http://localhost:5000

# Google OAuth — add redirect URIs in Google Cloud Console → Credentials → OAuth client
# Local:  http://localhost:5000/api/auth/google/callback
# Prod:   https://studentportal.mentorsdaily.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

OPENROUTER_API_KEY=your-openrouter-api-key-here
# Vision copy evaluation — flash-lite default (override if quality drops)
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite
# Legacy vision model fallback (not used for MCQ gen)
OPENROUTER_MODEL=google/gemini-2.5-flash
# Cheapest model for high-volume tasks (MCQ gen, translation, relevance, CA)
OPENROUTER_CHEAP_MODEL=google/gemini-2.5-flash-lite
# Chat / planner / profiler
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash-lite
# Prelims MCQ generator — low-cost model, batched bilingual generation
OPENROUTER_TEST_MODEL=google/gemini-2.5-flash-lite
# Topic practice dedicated model
OPENROUTER_PRACTICE_MODEL=google/gemini-2.5-flash-lite
# Response cache TTL for idempotent calls (translation, CA relevance). 0 = off
OPENROUTER_CACHE_TTL_SEC=3600
OPENROUTER_CACHE_MAX_ENTRIES=500
# Token budgets (cost tuning)
VISION_MAX_TOKENS=6144
PLANNER_MAX_TOKENS=1200
JSON_MAX_TOKENS=1200
COST_WARN_INR=1
INR_PER_USD=83
# Hindi batch translation: strings per API call (50Q practice ≈ 2-4 calls vs 300+)
HINDI_TRANSLATE_BATCH_SIZE=80
TRANSLATION_CACHE_TTL_SEC=604800
# Output token budget per batch
TEST_GEN_TOKENS_PER_QUESTION=300
TEST_GEN_MAX_OUTPUT_TOKENS=3500
TEST_GEN_BATCH_SIZE=8
# Set true to generate explanation_en + explanation_hi for all 4 options (higher token cost)
# TEST_GEN_FULL_BILINGUAL_EXPLANATIONS=false

# Admin Prelims Mock (Schedule Mock / Go Live) — same token profile as prelims test
MIX_BATCH_SIZE=15
MIX_GENERATE_BUFFER=20
MIX_MAX_REFILL_BATCHES=8

# --- Topic Practice (admin 50Q) — token / cost tuning ---
# Dedicated model (cheapest flash-lite recommended)
# OPENROUTER_PRACTICE_MODEL=google/gemini-2.5-flash-lite
# English MCQs first (~50% cheaper), then 1–2 Hindi batch calls (default)
PRACTICE_GEN_ENGLISH_ONLY=true
PRACTICE_GEN_BATCH_HINDI=true
# Set false for lowest cost (English-only tests, no Hindi)
# PRACTICE_GEN_BATCH_HINDI=false
PRACTICE_BATCH_SIZE=12
PRACTICE_GENERATE_BUFFER=5
PRACTICE_GEN_TOKENS_PER_QUESTION=280
PRACTICE_MAX_OUTPUT_TOKENS=3500
PRACTICE_MAX_REFILL_BATCHES=5
PRACTICE_HINDI_BATCH_SIZE=80
# Bulk mixed-pattern generation (default). Set true only if quality issues: PRACTICE_USE_PER_PATTERN_GENERATION=true
PRACTICE_HINDI_TOKENS_PER_QUESTION=360
PRACTICE_HINDI_MAX_OUTPUT_TOKENS=5000
# TEST_GEN_FULL_MOCK_VERBOSE=true
# Hindi is included in the same OpenRouter call (recommended). Keep false.
ENABLE_HINDI_TRANSLATION=false
# Only if you need legacy per-field Hindi API calls (many extra hits):
# TEST_GEN_USE_SEPARATE_HINDI_TRANSLATION=true

# Optional: Cloudinary for future cloud storage of copies
CLOUDINARY_URL=

# GNews API (Daily UPSC Current Affairs)
GNEWS_API_KEY=your-gnews-api-key-here
# Optional: OpenRouter headers (usually not needed)
# OPENROUTER_HTTP_REFERER=https://studentportal.mentorsdaily.com
# OPENROUTER_X_TITLE=UPSC Mentor

# Current Affairs Research API Keys
NEWSAPI_KEY=your-newsapi-org-api-key
THE_HINDU_API_KEY=your-thehindu-api-key
PIB_API_KEY=your-pib-api-key
INDIAN_EXPRESS_API_KEY=your-indianexpress-api-key

# Research Configuration
RESEARCH_MAX_RETRIES=3
RESEARCH_TIMEOUT=30000
RESEARCH_CONCURRENCY=2
SCHEDULER_TIMEZONE=UTC

# Admin Configuration
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-secure-admin-password