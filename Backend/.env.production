PORT=5000
DATABASE_URL=your-production-mongodb-connection-string
JWT_SECRET=supersecretjwtkey

# Production frontend and backend host values
CLIENT_ORIGIN=https://studentportal.mentorsdaily.com
CLIENT_URL=https://studentportal.mentorsdaily.com
FRONTEND_URL=https://studentportal.mentorsdaily.com
BASE_URL=https://studentportal.mentorsdaily.com
BACKEND_URL=https://studentportal.mentorsdaily.com
SERVER_URL=https://studentportal.mentorsdaily.com

# Google OAuth production redirect URI
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_CALLBACK_URL=https://studentportal.mentorsdaily.com/api/auth/google/callback

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENAI_API_KEY=your-openai-compatible-key

# Payment, email, and other production secrets
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM_EMAIL=your@domain.com
SMTP_FROM_NAME=MentorsDaily

# OTP settings
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
