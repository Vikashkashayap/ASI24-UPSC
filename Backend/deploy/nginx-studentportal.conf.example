# /etc/nginx/sites-available/studentportal.mentorsdaily.com
# Frontend build: /var/www/studentportal/frontend/dist
# Backend (PM2): 127.0.0.1:5000

server {
    listen 80;
    listen [::]:80;
    server_name studentportal.mentorsdaily.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name studentportal.mentorsdaily.com;

    # ssl_certificate /etc/letsencrypt/live/studentportal.mentorsdaily.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/studentportal.mentorsdaily.com/privkey.pem;

    root /var/www/studentportal/frontend/dist;
    index index.html;

    # API + Google OAuth → Node (required for /api/auth/google)
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Socket.IO (if used)
    location /socket.io/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA — must be after /api/
    location / {
        try_files $uri $uri/ /index.html;
    }
}
